# mma-mcp Caddy HTTPS 配置示例
#
# 前提：使用带 alidns 插件的 Caddy，用 DNS-01 验证申请 Let's Encrypt 证书。
# 不需要开放 80 端口，只需 443。
#
# 构建带 alidns 插件的 Caddy：
#   xcaddy build --with github.com/caddy-dns/alidns
#
# 运行时需要设置以下环境变量：
#   ALIDNS_ACCESS_KEY_ID      — 阿里云 RAM 子账号 AccessKey ID
#   ALIDNS_ACCESS_KEY_SECRET  — 阿里云 RAM 子账号 AccessKey Secret
#
# RAM 子账号所需权限：AliyunDNSFullAccess（或最小化：dns:AddDomainRecord 等）
#
# 启动：
#   sudo ALIDNS_ACCESS_KEY_ID=xxx ALIDNS_ACCESS_KEY_SECRET=yyy caddy run --config Caddyfile

{
    # 全局使用 DNS-01 验证，无需开放 80 端口
    acme_dns alidns {
        access_key_id     {$ALIDNS_ACCESS_KEY_ID}
        access_key_secret {$ALIDNS_ACCESS_KEY_SECRET}
    }
}

mma-mcp.yourdomain.com {
    # mma-mcp 以 HTTP 模式监听本地 8000 端口
    # header_up Host 将请求头替换为 localhost:8000，
    # 避免触发 FastMCP 的 DNS rebinding 保护
    reverse_proxy localhost:8000 {
        header_up Host {upstream_hostport}
    }

    # 可选：简单的 Bearer Token 认证（在 Caddy 层拦截未授权请求）
    # 取消注释并替换 your-secret-token 以启用
    # @unauthorized not header Authorization "Bearer your-secret-token"
    # respond @unauthorized 401
}
